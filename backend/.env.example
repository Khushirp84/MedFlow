# Rename this file to .env and fill in real values. Never commit .env.

# Security
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Database
DATABASE_URL=sqlite:///./medflow.db

# Gemini (get a free key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db

# Tesseract binary path (only needed if not on system PATH)
TESSERACT_CMD=

# Tesseract page segmentation mode:
# 3  = Fully automatic page segmentation (Tesseract default)
# 6  = Assume a single uniform block of text (recommended for medical notes/prescriptions)
# 11 = Sparse text mode (useful for forms with scattered text)
TESSERACT_PSM=6
